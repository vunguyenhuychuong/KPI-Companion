# ===== LLM (Qwen qua endpoint OpenAI-compatible) =====
# Vi du DashScope:  https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Vi du OpenRouter: https://openrouter.ai/api/v1
# Vi du vLLM noi bo: http://10.0.0.5:8000/v1
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=qwen3.5-plus
LLM_TEMPERATURE=0.2
# Tat thinking mode cua Qwen3 — giam latency ~24 lan (12s -> 0.5s moi call).
# Chi dat false neu endpoint bao loi tham so khong hop le.
LLM_DISABLE_THINKING=true
# ===== Database =====
# Duong dan tuong doi (./) se tu dong resolve theo thu muc backend, KHONG phu
# thuoc thu muc chay -> deploy/agentbase/may khac deu tro ve cung 1 file DB.
# Muon dat noi khac: dung duong dan tuyet doi, vd sqlite:///D:/data/kpi.db
DATABASE_URL=sqlite:///./kpi_companion.db

# ===== Google integrations =====
# De trong / khong co file credentials.json -> tu dong dung MOCK DATA de demo.
# Khi co OAuth credentials that: dat file credentials.json (loai "Web application")
# vao thu muc backend/ va doi GOOGLE_MOCK_MODE=false
GOOGLE_MOCK_MODE=true
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# ===== OAuth ket noi nguon du lieu tu giao dien (Connect button) =====
# OAUTH_REDIRECT_BASE: goc URL CONG KHAI cua backend. redirect_uri se la
#   {base}/api/oauth/{provider}/callback  -> PHAI khai bao y het trong console cua nha cung cap.
OAUTH_REDIRECT_BASE=http://localhost:8000
# FRONTEND_URL: noi tra trinh duyet ve sau khi ket noi xong.
FRONTEND_URL=http://localhost:5173/sources
# Ma hoa token OAuth luu trong DB. De trong -> tu suy ra tu JWT_SECRET_KEY (chay duoc ngay).
# Khi deploy that, tao key rieng:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ===== Phase 3 (tuy chon) — Notion / Slack / Outlook =====
# Dang ky OAuth app o moi nha cung cap, dat redirect_uri = {OAUTH_REDIRECT_BASE}/api/oauth/<provider>/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# ===== Email (SMTP) =====
# Dung de gui email that qua Gmail
# App Password: lay tu https://myaccount.google.com/apppasswords (can bat 2-Factor Authentication)
# Vi du: SMTP_EMAIL=ban@gmail.com, SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
